---
import { getCollection, getEntry } from 'astro:content';
import Layout from './Layout.astro';
import Header from '../components/shared/header/Header.astro';
import Footer from '../components/shared/footer/Footer.astro';
import ServicePageHeader from '../components/services/single/ServicePageHeader.astro';
import ServiceSidebar from '../components/services/single/ServiceSidebar.astro';
import ServiceSingleImage from '../components/services/single/ServiceSingleImage.astro';
import ServiceFaqs from '../components/services/single/ServiceFaqs.astro';

const { frontmatter } = Astro.props;
const cluster = frontmatter.cluster;
const pillar = await getEntry('services', cluster);
const hubUrl = `/services/${cluster}`;
const hubTitle = pillar?.data.title ?? 'Услуги';

const siblings = (
	await getCollection('serviceLanding', ({ data }) => data.cluster === cluster)
)
	.sort((a, b) => a.data.order - b.data.order)
	.map((entry) => ({
		title: entry.data.title,
		url: `/services/${entry.id}`,
	}));

const sidebarLinks = [{ title: `Все услуги: ${hubTitle}`, url: hubUrl }, ...siblings];

const seoTitle = frontmatter.seo?.title ?? `${frontmatter.title} — техпомощь в Тюмени`;
const seoDescription = frontmatter.seo?.description ?? frontmatter.description;
const faqs = frontmatter.faqs ?? [];
const image = frontmatter.image ?? '/images/service-single-image.jpg';
const imageAlt = frontmatter.imageAlt ?? frontmatter.title;
---

<Layout title={seoTitle} description={seoDescription}>
	<Header />

	<ServicePageHeader title={frontmatter.title} />

	<!-- Page Service Single Start -->
	<div class="page-service-single">
		<div class="container">
			<div class="row">
				<div class="col-lg-4">
					<ServiceSidebar links={sidebarLinks} />
				</div>

				<div class="col-lg-8">
					<!-- Service Single Content Start -->
					<div class="service-single-content">
						<ServiceSingleImage image={image} alt={imageAlt} />

						<!-- Service Entry Start -->
						<div class="service-entry post-body">
							<slot />
						</div>
						<!-- Service Entry End -->

						<ServiceFaqs faqs={faqs} />
					</div>
					<!-- Service Single Content End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Service Single End -->

	<Footer />
</Layout>
