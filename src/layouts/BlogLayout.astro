---
import Layout from './Layout.astro';
import Header from '../components/shared/header/Header.astro';
import Footer from '../components/shared/footer/Footer.astro';
import BlogSingleHeader from '../components/blog/BlogSingleHeader.astro';
import BlogSingleImage from '../components/blog/BlogSingleImage.astro';
import BlogPostTagLinks from '../components/blog/BlogPostTagLinks.astro';

const { frontmatter } = Astro.props;
const seoTitle = frontmatter.seo?.title ?? `${frontmatter.title} — блог «За рулём»`;
const seoDescription = frontmatter.seo?.description ?? frontmatter.description;
const dateLabel = frontmatter.date
	? new Date(frontmatter.date).toLocaleDateString('ru-RU', {
			day: 'numeric',
			month: 'long',
			year: 'numeric',
		})
	: '';
---

<Layout title={seoTitle} description={seoDescription} ogImage={frontmatter.image}>
	<Header />

	<BlogSingleHeader title={frontmatter.title} author={frontmatter.author} dateLabel={dateLabel} />

	<!-- Page Single Post Start -->
	<div class="page-single-post">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					{
						frontmatter.image && (
							<BlogSingleImage
								image={frontmatter.image}
								imageAlt={frontmatter.imageAlt ?? frontmatter.title}
							/>
						)
					}

					<!-- Post Single Content Start -->
					<div class="post-content">
						<!-- Post Entry Start -->
						<div class="post-entry">
							<slot />
						</div>
						<!-- Post Entry End -->

						<BlogPostTagLinks tags={frontmatter.tags} />
					</div>
					<!-- Post Single Content End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Single Post End -->

	<Footer />
</Layout>
