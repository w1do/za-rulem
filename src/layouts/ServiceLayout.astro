---
import Layout from './Layout.astro';
import Header from '../components/shared/header/Header.astro';
import Footer from '../components/shared/footer/Footer.astro';
import ServicePageHeader from '../components/services/single/ServicePageHeader.astro';
import ServiceSidebar from '../components/services/single/ServiceSidebar.astro';
import ServiceSingleImage from '../components/services/single/ServiceSingleImage.astro';
import ServiceWhyChoose from '../components/services/single/ServiceWhyChoose.astro';
import ServiceFeatures from '../components/services/single/ServiceFeatures.astro';
import ServiceProcess from '../components/services/single/ServiceProcess.astro';
import ServiceFaqs from '../components/services/single/ServiceFaqs.astro';
import { serviceNode, breadcrumbNode, faqNode } from '../lib/seo';

const { frontmatter, spokes = [] } = Astro.props;
const seoTitle = frontmatter.seo?.title ?? `${frontmatter.title} — техпомощь в Тюмени`;
const seoDescription = frontmatter.seo?.description ?? frontmatter.description;

const image = frontmatter.image ?? '/images/service-single-image.jpg';
const imageAlt = frontmatter.title;

const jsonLd = [
	serviceNode({
		name: frontmatter.title,
		description: frontmatter.description,
		url: Astro.url.pathname,
	}),
	breadcrumbNode([
		{ name: 'Главная', url: '/' },
		{ name: 'Услуги', url: '/services' },
		{ name: frontmatter.title, url: Astro.url.pathname },
	]),
	faqNode(frontmatter.faqs),
].filter(Boolean);

const sidebarLinks = spokes.map((spoke) => ({ title: spoke.title, url: spoke.url }));

const process = frontmatter.process;
const steps = process
	? [
			{ title: process.step1Title, description: process.step1Desc },
			{ title: process.step2Title, description: process.step2Desc },
			{ title: process.step3Title, description: process.step3Desc },
			{ title: process.step4Title, description: process.step4Desc },
		].filter((s) => s.title)
	: [];
---

<Layout title={seoTitle} description={seoDescription} jsonLd={jsonLd}>
	<Header />

	<ServicePageHeader title={frontmatter.title} />

	<!-- Page Service Single Start -->
	<div class="page-service-single">
		<div class="container">
			<div class="row">
				<div class="col-lg-4">
					<ServiceSidebar links={sidebarLinks} />
				</div>

				<div class="col-lg-8">
					<!-- Service Single Content Start -->
					<div class="service-single-content">
						<ServiceSingleImage image={image} alt={imageAlt} />

						<!-- Service Entry Start -->
						<div class="service-entry post-body">
							<slot />

							<ServiceWhyChoose
								title={frontmatter.featuresTitle}
								description={frontmatter.featuresDescription}
								items={frontmatter.features}
							/>

							<ServiceFeatures
								title={frontmatter.offersTitle}
								description={frontmatter.offersDescription}
								items={frontmatter.offers}
							/>

							<ServiceProcess
								title={process?.title}
								steps={steps}
							/>
						</div>
						<!-- Service Entry End -->

						<ServiceFaqs faqs={frontmatter.faqs} />
					</div>
					<!-- Service Single Content End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Service Single End -->

	<Footer />
</Layout>
