---
import Layout from '../layouts/Layout.astro';
import Header from '../components/shared/header/Header.astro';
import Footer from '../components/shared/footer/Footer.astro';
import CallbackForm from '../components/forms/CallbackForm.tsx';

import HomeHero from '../components/home/HomeHero.astro';
import HomeAbout from '../components/home/HomeAbout.astro';
import HomeServices from '../components/home/HomeServices.astro';
import HomeWhyChoose from '../components/home/HomeWhyChoose.astro';
import HomeFleets from '../components/home/HomeFleets.astro';
import HomeWhatWeDo from '../components/home/HomeWhatWeDo.astro';
import HomeCollection from '../components/home/HomeCollection.astro';
import HomeDrivers from '../components/home/HomeDrivers.astro';
import HomeHowItWork from '../components/home/HomeHowItWork.astro';
import HomeTestimonials from '../components/home/HomeTestimonials.astro';
import HomePricing from '../components/home/HomePricing.astro';
import HomeBlog from '../components/home/HomeBlog.astro';

import { webPageNode, itemListNode } from '../lib/seo';

// Структурированные данные главной: описание страницы и каталог ключевых услуг.
const jsonLd = [
	webPageNode({
		type: 'WebPage',
		name: 'Автопомощь и техпомощь на дороге в Тюмени — срочный выезд 24/7',
		description:
			'Срочная автопомощь и техпомощь на дороге в Тюмени с выездом: прикурить авто, замена аккумулятора, отогрев машины, подвоз топлива, автоэлектрик, диагностика и эвакуация круглосуточно.',
		url: '/',
	}),
	itemListNode([
		{ name: 'Прикурить авто', url: '/services/tehpomosch/prikurit-avto' },
		{ name: 'Замена аккумулятора с выездом', url: '/services/tehpomosch/zamena-akkumulyatora' },
		{ name: 'Отогрев автомобиля', url: '/services/tehpomosch/otogrev-avto' },
		{ name: 'Подвоз бензина', url: '/services/toplivo/podvoz-benzina' },
		{ name: 'Подвоз дизеля', url: '/services/toplivo/podvoz-dizelya' },
	]),
];
---

<Layout
	title="Автопомощь и техпомощь на дороге в Тюмени — срочный выезд 24/7"
	description="Срочная автопомощь и техпомощь на дороге в Тюмени с выездом: прикурю авто, заменю аккумулятор, отогрею машину, привезу топливо. Приеду за 20–40 минут круглосуточно."
	ogTitle="Автопомощь и техпомощь в Тюмени — срочный выезд 24/7"
	ogDescription="Застряли на дороге в Тюмени? Звоните — срочно приеду с выездом и заведу вашу машину в любое время суток."
	keywords="автопомощь тюмень, техпомощь на дороге тюмень, срочно техпомощь тюмень с выездом, прикурить авто, замена аккумулятора с выездом, отогрев автомобиля, эвакуатор тюмень"
	jsonLd={jsonLd}
>
	<Header />

	<HomeHero />
	<HomeAbout />
	<HomeServices />
	<HomeWhyChoose />
	<HomeFleets />
	<HomeWhatWeDo />
	<HomeCollection />
	<HomeDrivers />
	<HomeHowItWork />
	<HomeTestimonials />
	<HomePricing />
	<HomeBlog />
	<Footer />
</Layout>
