---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/shared/header/Header.astro';
import Footer from '../../components/shared/footer/Footer.astro';
import ServiceCard from '../../components/services/ServiceCard.astro';

// Каталог показывает отдельные услуги (spokes), а не хабы-кластеры.
const spokes = (await getCollection('serviceLanding')).sort(
	(a, b) => a.data.order - b.data.order,
);

const cards = spokes.map((entry, i) => ({
	title: entry.data.title,
	description: entry.data.excerpt ?? entry.data.description,
	icon: entry.data.icon,
	url: `/services/${entry.id}`,
	delay: i % 3 === 0 ? undefined : `${(i % 3) * 0.2}s`,
}));

import { webPageNode, breadcrumbNode, itemListNode } from '../../lib/seo';

const jsonLd = [
	webPageNode({
		type: 'CollectionPage',
		name: 'Услуги автопомощи и техпомощи на дороге в Тюмени',
		description:
			'Все услуги автопомощи и техпомощи на дороге в Тюмени с выездом: прикурить авто, замена аккумулятора, отогрев, подвоз топлива, автоэлектрик и диагностика. Приеду на место круглосуточно.',
		url: '/services',
	}),
	breadcrumbNode([
		{ name: 'Главная', url: '/' },
		{ name: 'Услуги', url: '/services' },
	]),
	itemListNode(cards.map((card) => ({ name: card.title, url: card.url }))),
];
---

<Layout
	title="Услуги техпомощи на дороге в Тюмени — выезд 24/7 | За рулём"
	description="Все услуги автопомощи в Тюмени: прикурить авто, замена аккумулятора, отогрев, подвоз топлива, автоэлектрик и диагностика. Приеду на место круглосуточно."
	keywords="услуги техпомощи тюмень, прикурить авто, замена аккумулятора с выездом, отогрев автомобиля, подвоз топлива"
	jsonLd={jsonLd}
>
	<Header />

	<!-- Page Header Section Start -->
	<div class="page-header parallaxie">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<!-- Page Header Box Start -->
					<div class="page-header-box">
						<h1 class="text-anime-style-3" data-cursor="-opaque">Мои услуги</h1>
						<nav class="wow fadeInUp">
							<ol class="breadcrumb">
								<li class="breadcrumb-item"><a href="/">главная</a></li>
								<li class="breadcrumb-item active" aria-current="page">Услуги</li>
							</ol>
						</nav>
					</div>
					<!-- Page Header Box End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Header Section End -->

	<!-- page Services Start -->
	<div class="page-services">
		<div class="container">
			<div class="row">
				{
					cards.map((card) => (
						<ServiceCard
							title={card.title}
							description={card.description}
							icon={card.icon}
							url={card.url}
							delay={card.delay}
						/>
					))
				}
			</div>
		</div>
	</div>
	<!-- page Services End -->

	<Footer />
</Layout>
