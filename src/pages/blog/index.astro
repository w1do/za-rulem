---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/shared/header/Header.astro';
import Footer from '../../components/shared/footer/Footer.astro';
import BlogPageHeader from '../../components/blog/BlogPageHeader.astro';
import PostCard from '../../components/blog/PostCard.astro';
import BlogPagination from '../../components/blog/BlogPagination.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
);

const POSTS_PER_PAGE = 9;
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
---

<Layout
	title="Блог о техпомощи на дороге — советы автовладельцам Тюмени | За рулём"
	description="Разбираю частые дорожные ситуации: почему не заводится авто, как прикурить машину, что делать в мороз и как выбрать аккумулятор. Опыт мастера из Тюмени."
	keywords="блог техпомощь тюмень, не заводится авто, как прикурить машину, отогрев авто, выбор аккумулятора"
>
	<Header />

	<BlogPageHeader title="Блог" breadcrumb="Блог" />

	<!-- Page Blog Start -->
	<div class="page-blog">
		<div class="container">
			<div class="row">
				{
					posts.map((post, i) => (
						<PostCard
							title={post.data.title}
							image={post.data.image}
							imageAlt={post.data.imageAlt}
							url={`/blog/${post.id}`}
							delay={i % 3 === 0 ? undefined : `${(i % 3) * 0.2}s`}
						/>
					))
				}

				<BlogPagination currentPage={1} totalPages={totalPages} basePath="/blog" />
			</div>
		</div>
	</div>
	<!-- Page Blog End -->

	<Footer />
</Layout>
