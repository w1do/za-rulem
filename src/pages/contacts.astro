---
import Layout from '../layouts/Layout.astro';
import Header from '../components/shared/header/Header.astro';
import Footer from '../components/shared/footer/Footer.astro';
import ContactForm from '../components/forms/ContactForm.tsx';
---

<Layout
	title="Контакты — техпомощь на дороге в Тюмени | За рулём"
	description="Свяжитесь со мной для вызова техпомощи в Тюмени и области: телефон +7 908 871-20-26, выезд круглосуточно. Оставьте заявку — перезвоню в течение пары минут."
	keywords="контакты техпомощь тюмень, вызвать автопомощь тюмень, телефон техпомощь на дороге"
>
	<Header />

	<!-- Page Header Section Start -->
	<div class="page-header parallaxie">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<!-- Page Header Box Start -->
					<div class="page-header-box">
						<h1 class="text-anime-style-3" data-cursor="-opaque">Контакты</h1>
						<nav class="wow fadeInUp">
							<ol class="breadcrumb">
								<li class="breadcrumb-item"><a href="/">главная</a></li>
								<li class="breadcrumb-item active" aria-current="page">Контакты</li>
							</ol>
						</nav>
					</div>
					<!-- Page Header Box End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Header Section End -->

	<!-- Page Contact Us Start -->
	<div class="page-contact-us">
		<div class="container">
			<div class="row">
				<div class="col-xl-6">
					<!-- Contact Us Image Box Start -->
					<div class="contact-us-image-box">
						<!-- Contact us Image Start -->
						<div class="contact-us-image">
							<figure class="image-anime reveal">
								<img src="/images/contact-us-image.jpg" alt="Техпомощь на дороге в Тюмени" />
							</figure>
						</div>
						<!-- Contact us Image End -->

						<!-- Contact Info Content Box Start -->
						<div class="contact-info-content-box">
							<!-- Contact Info Title Start -->
							<div class="contact-info-title wow fadeInUp">
								<h2>Как со мной связаться:</h2>
							</div>
							<!-- Contact Info Title End -->

							<!-- Contact Info List Start -->
							<div class="contact-info-list wow fadeInUp" data-wow-delay="0.2s">
								<!-- Contact Info Item Start -->
								<div class="contact-info-item">
									<div class="icon-box">
										<img src="/images/icon-phone-primary.svg" alt="Телефон" />
									</div>
									<div class="contact-info-item-content">
										<p>Звоните круглосуточно:</p>
										<h3><a href="tel:+79088712026">+7 908 871-20-26</a></h3>
									</div>
								</div>
								<!-- Contact Info Item End -->

								<!-- Contact Info Item Start -->
								<div class="contact-info-item">
									<div class="icon-box">
										<img src="/images/icon-mail-primary.svg" alt="Зона выезда" />
									</div>
									<div class="contact-info-item-content">
										<p>Зона выезда:</p>
										<h3>Тюмень и Тюменская область</h3>
									</div>
								</div>
								<!-- Contact Info Item End -->
							</div>
							<!-- Contact Info List End -->
						</div>
						<!-- Contact Info Content Box End -->
					</div>
					<!-- Contact Us Image Box End -->
				</div>

				<div class="col-xl-6">
					<!-- Contact Us Form Start -->
					<div class="contact-us-form">
						<!-- Section Title Start -->
						<div class="section-title">
							<span class="section-sub-title wow fadeInUp">Оставить заявку</span>
							<h2 class="text-anime-style-3" data-cursor="-opaque">Свяжитесь со мной</h2>
							<p class="wow fadeInUp" data-wow-delay="0.2s">
								Опишите ситуацию на дороге и оставьте номер — я перезвоню в течение
								пары минут и выеду к вам в Тюмени или области. Работаю круглосуточно.
							</p>
						</div>
						<!-- Section Title End -->

						<!-- Contact Form Start -->
						<div class="contact-form wow fadeInUp" data-wow-delay="0.4s">
							<ContactForm client:visible subject="Заявка со страницы контактов" />
						</div>
						<!-- Contact Form End -->
					</div>
					<!-- Contact Us Form End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Page Contact Us End -->

	<!-- Google Map Start -->
	<div class="google-map">
		<div class="container">
			<div class="row section-row">
				<div class="col-lg-12">
					<!-- Section Title Start -->
					<div class="section-title section-title-center">
						<span class="section-sub-title wow fadeInUp">Зона выезда</span>
						<h2 class="text-anime-style-3" data-cursor="-opaque">Работаю по Тюмени и области</h2>
						<p class="wow fadeInUp" data-wow-delay="0.2s">
							Выезжаю в любой район Тюмени и по Тюменской области. Позвоните
							или оставьте заявку — доеду до вас, где бы вы ни остановились.
						</p>
					</div>
					<!-- Section Title End -->
				</div>
			</div>

			<div class="row">
				<div class="col-lg-12">
					<!-- Google Map Start -->
					<div class="google-map-iframe wow fadeInUp" data-wow-delay="0.4s">
						<iframe
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d305234.0!2d65.28!3d57.15!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2z0KLRjtC80LXQvdGM!5e0!3m2!1sru!2sru!4v1703158537552"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"></iframe>
					</div>
					<!-- Google Map End -->
				</div>
			</div>
		</div>
	</div>
	<!-- Google Map End -->

	<Footer />
</Layout>
