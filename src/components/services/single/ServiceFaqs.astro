---
const { faqs = [], title = 'Частые вопросы' } = Astro.props;
---

{
	faqs.length > 0 && (
		<div class="page-single-faqs">
			<!-- Section Title Start -->
			<div class="section-title">
				<h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
			</div>
			<!-- Section Title End -->

			<!-- FAQ Accordion Start -->
			<div class="faq-accordion" id="accordion">
				{faqs.map((faq, i) => (
					<div class="accordion-item wow fadeInUp" data-wow-delay={`${i * 0.2}s`}>
						<h2 class="accordion-header" id={`heading${i}`}>
							<button
								class={i === 0 ? 'accordion-button' : 'accordion-button collapsed'}
								type="button"
								data-bs-toggle="collapse"
								data-bs-target={`#collapse${i}`}
								aria-expanded={i === 0 ? 'true' : 'false'}
								aria-controls={`collapse${i}`}
							>
								{faq.question}
							</button>
						</h2>
						<div
							id={`collapse${i}`}
							class={i === 0 ? 'accordion-collapse collapse show' : 'accordion-collapse collapse'}
							role="region"
							aria-labelledby={`heading${i}`}
							data-bs-parent="#accordion"
						>
							<div class="accordion-body">
								<p>{faq.answer}</p>
							</div>
						</div>
					</div>
				))}
			</div>
			<!-- FAQ Accordion End -->
		</div>
	)
}
