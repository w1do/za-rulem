---
import SpokeCard from './SpokeCard.astro';
const { spokes = [], title = 'Направления услуги' } = Astro.props;
---

<div class="cluster-spokes">
	<div class="row">
		<div class="col-lg-12">
			<div class="section-title">
				<span class="section-sub-title">Что входит в направление</span>
				<h2>{title}</h2>
			</div>
		</div>
	</div>
	<div class="row service-offer-item-list">
		{
			spokes.map((spoke) => (
				<SpokeCard
					title={spoke.title}
					description={spoke.description}
					excerpt={spoke.excerpt}
					icon={spoke.icon}
					url={spoke.url}
				/>
			))
		}
	</div>
</div>
