---
import ServiceCard from '../ServiceCard.astro';
const { spokes = [], title = 'Мои услуги в этом направлении' } = Astro.props;
---

<div class="cluster-spokes">
	<div class="row section-row">
		<div class="col-lg-12">
			<div class="section-title">
				<span class="section-sub-title">Что входит в направление</span>
				<h2>{title}</h2>
			</div>
		</div>
	</div>
	<!-- page Services Start -->
	<div class="page-services">
		<div class="row">
			{
				spokes.map((spoke, i) => (
					<ServiceCard
						title={spoke.title}
						description={spoke.excerpt ?? spoke.description}
						icon={spoke.icon}
						url={spoke.url}
						delay={i % 3 === 0 ? undefined : `${(i % 3) * 0.2}s`}
					/>
				))
			}
		</div>
	</div>
	<!-- page Services End -->
</div>
