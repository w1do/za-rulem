---
// Блок «Мой подход» хаба. Разметка перенесена из шаблона (our-apporach bg-section).
---

<!-- Our Approach Section Start -->
<div class="our-apporach bg-section">
	<div class="container">
		<div class="row section-row">
			<div class="col-xl-12">
				<!-- Section Title Start -->
				<div class="section-title section-title-center">
					<span class="section-sub-title wow fadeInUp">Мой подход</span>
					<h2 class="text-anime-style-3" data-cursor="-opaque">Я решаю проблему на месте, без лишнего ожидания</h2>
				</div>
				<!-- Section Title End -->
			</div>
		</div>

		<div class="row">
			<div class="col-xl-6">
				<!-- Approach Item List Start -->
				<div class="approach-item-list">
					<!-- Approach Item Start -->
					<div class="approach-item wow fadeInUp">
						<div class="approach-item-header">
							<div class="icon-box">
								<img src="/images/icon-approach-item-1.svg" alt="Быстрый выезд" />
							</div>
							<div class="approach-item-content">
								<h3>Быстрый выезд</h3>
								<p>Я беру трубку сам и выезжаю к машине с нужным оборудованием.</p>
							</div>
						</div>
						<div class="approach-item-body-list">
							<ul>
								<li>Подача по Тюмени за 20–40 минут</li>
								<li>Работаю круглосуточно, включая мороз</li>
							</ul>
						</div>
					</div>
					<!-- Approach Item End -->

					<!-- Approach Item Start -->
					<div class="approach-item wow fadeInUp" data-wow-delay="0.2s">
						<div class="approach-item-header">
							<div class="icon-box">
								<img src="/images/icon-approach-item-2.svg" alt="Честный расчёт" />
							</div>
							<div class="approach-item-content">
								<h3>Честный расчёт</h3>
								<p>Я называю цену до выезда и не навязываю лишние работы.</p>
							</div>
						</div>
						<div class="approach-item-body-list">
							<ul>
								<li>Оплата наличными или переводом на месте</li>
								<li>Объясняю причину поломки простыми словами</li>
							</ul>
						</div>
					</div>
					<!-- Approach Item End -->
				</div>
				<!-- Approach Item List End -->
			</div>

			<div class="col-xl-6">
				<!-- Approach Image Start -->
				<div class="approach-image">
					<figure class="image-anime reveal">
						<img src="/images/approach-image.jpg" alt="Выездная автопомощь в Тюмени" />
					</figure>
				</div>
				<!-- Approach Image End -->
			</div>

			<div class="col-lg-12">
				<!-- Section Footer Text Start -->
				<div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.2s">
					<!-- Satisfy Client Images Start -->
					<div class="satisfy-client-images">
						<div class="satisfy-client-image">
							<figure class="image-anime">
								<img src="/images/author-1.jpg" alt="Мастер техпомощи" />
							</figure>
						</div>
						<div class="satisfy-client-image add-more">
							<img src="/images/icon-phone-primary.svg" alt="Телефон" />
						</div>
					</div>
					<!-- Satisfy Client Images End -->
					<p>Полный список дорожной помощи — <a href="/services">смотреть услуги</a></p>
					<ul>
						<li><span class="counter">24</span>/7</li>
						<li>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
						</li>
						<li>На связи круглосуточно</li>
					</ul>
				</div>
				<!-- Section Footer Text End -->
			</div>
		</div>
	</div>
</div>
<!-- Our Approach Section End -->
