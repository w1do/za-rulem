---
// Блок отзывов хаба. Разметка перенесена из шаблона (our-testimonials + swiper).
---

<!-- Our Testimonials Section Start -->
<div class="our-testimonials">
	<div class="container">
		<div class="row section-row">
			<div class="col-lg-12">
				<!-- Section Title Start -->
				<div class="section-title section-title-center">
					<span class="section-sub-title wow fadeInUp">Отзывы</span>
					<h2 class="text-anime-style-3" data-cursor="-opaque">Реальные истории помощи, которым доверяют</h2>
				</div>
				<!-- Section Title End -->
			</div>
		</div>

		<div class="row">
			<div class="col-lg-12">
				<!-- Testimonial Slide Start -->
				<div class="testimonial-slider wow fadeInUp" data-wow-delay="0.2s">
					<div class="swiper" data-cursor-text="Перетащить">
						<div class="swiper-wrapper">
							<!-- Testimonial Slide Start -->
							<div class="swiper-slide">
								<!-- Testimonial Item Start -->
								<div class="testimonial-item">
									<!-- Testimonial Item Image Start -->
									<div class="testimonial-item-image">
										<figure>
											<img src="/images/testimonial-image.jpg" alt="Отзыв о техпомощи в Тюмени" />
										</figure>
									</div>
									<!-- Testimonial Item Image End -->

									<!-- Testimonial Item Body Start -->
									<div class="testimonial-item-body">
										<!-- Testimonial Item Rating Start -->
										<div class="testimonial-item-rating">
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
										</div>
										<!-- Testimonial Item Rating End -->

										<!-- Testimonial Item Content Start -->
										<div class="testimonial-item-content">
											<p>“ Разрядился аккумулятор во дворе — приехали быстро, прикурили и завели машину. Всё чётко и аккуратно.”</p>
										</div>
										<!-- Testimonial Item Content End -->

										<!-- Testimonial Author Content Start -->
										<div class="testimonial-author-content">
											<h2>Алексей</h2>
										</div>
										<!-- Testimonial Author Content End -->
									</div>
									<!-- Testimonial Item Body End -->
								</div>
								<!-- Testimonial Item End -->
							</div>
							<!-- Testimonial Slide End -->

							<!-- Testimonial Slide Start -->
							<div class="swiper-slide">
								<!-- Testimonial Item Start -->
								<div class="testimonial-item">
									<!-- Testimonial Item Image Start -->
									<div class="testimonial-item-image">
										<figure>
											<img src="/images/testimonial-image.jpg" alt="Отзыв об отогреве авто" />
										</figure>
									</div>
									<!-- Testimonial Item Image End -->

									<!-- Testimonial Item Body Start -->
									<div class="testimonial-item-body">
										<!-- Testimonial Item Rating Start -->
										<div class="testimonial-item-rating">
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
										</div>
										<!-- Testimonial Item Rating End -->

										<!-- Testimonial Item Content Start -->
										<div class="testimonial-item-content">
											<p>“ В сильный мороз машина не завелась. Помогли отогреть двигатель и подсказали, что делать дальше.”</p>
										</div>
										<!-- Testimonial Item Content End -->

										<!-- Testimonial Author Content Start -->
										<div class="testimonial-author-content">
											<h2>Марина</h2>
										</div>
										<!-- Testimonial Author Content End -->
									</div>
									<!-- Testimonial Item Body End -->
								</div>
								<!-- Testimonial Item End -->
							</div>
							<!-- Testimonial Slide End -->

							<!-- Testimonial Slide Start -->
							<div class="swiper-slide">
								<!-- Testimonial Item Start -->
								<div class="testimonial-item">
									<!-- Testimonial Item Image Start -->
									<div class="testimonial-item-image">
										<figure>
											<img src="/images/testimonial-image.jpg" alt="Отзыв о вскрытии авто" />
										</figure>
									</div>
									<!-- Testimonial Item Image End -->

									<!-- Testimonial Item Body Start -->
									<div class="testimonial-item-body">
										<!-- Testimonial Item Rating Start -->
										<div class="testimonial-item-rating">
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
										</div>
										<!-- Testimonial Item Rating End -->

										<!-- Testimonial Item Content Start -->
										<div class="testimonial-item-content">
											<p>“ Захлопнул ключи в машине у подъезда. Аккуратно вскрыли авто без повреждений, приехали ночью.”</p>
										</div>
										<!-- Testimonial Item Content End -->

										<!-- Testimonial Author Content Start -->
										<div class="testimonial-author-content">
											<h2>Дмитрий</h2>
										</div>
										<!-- Testimonial Author Content End -->
									</div>
									<!-- Testimonial Item Body End -->
								</div>
								<!-- Testimonial Item End -->
							</div>
							<!-- Testimonial Slide End -->

							<!-- Testimonial Slide Start -->
							<div class="swiper-slide">
								<!-- Testimonial Item Start -->
								<div class="testimonial-item">
									<!-- Testimonial Item Image Start -->
									<div class="testimonial-item-image">
										<figure>
											<img src="/images/testimonial-image.jpg" alt="Отзыв о подвозе топлива" />
										</figure>
									</div>
									<!-- Testimonial Item Image End -->

									<!-- Testimonial Item Body Start -->
									<div class="testimonial-item-body">
										<!-- Testimonial Item Rating Start -->
										<div class="testimonial-item-rating">
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
											<i class="fa-solid fa-star"></i>
										</div>
										<!-- Testimonial Item Rating End -->

										<!-- Testimonial Item Content Start -->
										<div class="testimonial-item-content">
											<p>“ Заглох на трассе без топлива. Быстро привезли бензин, помогли завестись и продолжить поездку.”</p>
										</div>
										<!-- Testimonial Item Content End -->

										<!-- Testimonial Author Content Start -->
										<div class="testimonial-author-content">
											<h2>Сергей</h2>
										</div>
										<!-- Testimonial Author Content End -->
									</div>
									<!-- Testimonial Item Body End -->
								</div>
								<!-- Testimonial Item End -->
							</div>
							<!-- Testimonial Slide End -->
						</div>
					</div>
				</div>
				<!-- Testimonial Slide End -->
			</div>

			<div class="col-lg-12">
				<!-- Section Footer Text Start -->
				<div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.2s">
					<!-- Satisfy Client Images Start -->
					<div class="satisfy-client-images">
						<div class="satisfy-client-image">
							<figure class="image-anime">
								<img src="/images/author-1.jpg" alt="Мастер техпомощи" />
							</figure>
						</div>
						<div class="satisfy-client-image add-more">
							<img src="/images/icon-phone-primary.svg" alt="Телефон" />
						</div>
					</div>
					<!-- Satisfy Client Images End -->
					<p>Я помогаю вернуть автомобиль на дорогу — <a href="/blog">читать отзывы</a></p>
					<ul>
						<li><span class="counter">24</span>/7</li>
						<li>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
							<i class="fa-solid fa-star"></i>
						</li>
						<li>На связи круглосуточно</li>
					</ul>
				</div>
				<!-- Section Footer Text End -->
			</div>
		</div>
	</div>
</div>
<!-- Our Testimonials Section End -->
