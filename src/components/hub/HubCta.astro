---
// Блок призыва к действию хаба. Разметка перенесена из шаблона (cta-box bg-section dark-section parallaxie).
---

<!-- CTA Section Start -->
<div class="cta-box bg-section dark-section parallaxie">
	<div class="container">
		<div class="row">
			<div class="col-xl-6">
				<div class="cta-box-content">
					<!-- Section Title Start -->
					<div class="section-title">
						<span class="section-sub-title wow fadeInUp">Связаться со мной</span>
						<h2 class="text-anime-style-3" data-cursor="-opaque">Нужна техпомощь на дороге?</h2>
						<p class="wow fadeInUp" data-wow-delay="0.2s">Я принимаю заявки на выезд в Тюмени и Тюменской области круглосуточно. Звонок или заявка помогут мне уточнить ситуацию и назвать цену заранее.</p>
					</div>
					<!-- Section Title End -->

					<!-- CTA Body Start -->
					<div class="cta-content-body wow fadeInUp" data-wow-delay="0.4s">
						<ul>
							<li>Выезжаю на место поломки</li>
							<li>Работаю круглосуточно, 24/7</li>
						</ul>
					</div>
					<!-- CTA Body End -->

					<!-- CTA Content Footer Start -->
					<div class="cta-content-footer wow fadeInUp" data-wow-delay="0.4s">
						<!-- CTA Button Start -->
						<div class="cta-content-btn">
							<a href="/contacts" class="btn-default btn-highlighted">Оставить заявку</a>
						</div>
						<!-- CTA Button End -->

						<!-- About Contact Box Start -->
						<div class="about-contact-box">
							<div class="icon-box">
								<img src="/images/icon-phone-primary.svg" alt="Телефон" />
							</div>
							<div class="about-contact-box-content">
								<p>Круглосуточно, 24/7</p>
								<h3><a href="tel:+79088712026">+7 908 871-20-26</a></h3>
							</div>
						</div>
						<!-- About Contact Box End -->
					</div>
					<!-- CTA Content Footer End -->
				</div>
			</div>
		</div>
	</div>
</div>
<!-- CTA Section End -->
