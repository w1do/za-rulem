---
// Блок карточек услуг хаба (перелинковка на посадочные страницы услуги).
// Использует ту же карточку, что и каталог /services (ServiceCard → service-item).
import ServiceCard from '../services/ServiceCard.astro';

const {
	subtitle = 'Услуги техпомощи',
	title = 'Выберите нужную услугу на дороге',
	services = [],
	footerText = 'Не нашли нужное? Я также вскрываю авто и подвожу топливо — <a href="/services">смотреть все услуги</a>',
} = Astro.props;
---

<!-- Our Service Section Start -->
<div class="our-services bg-section">
	<div class="container">
		<div class="row section-row">
			<div class="col-xl-12">
				<!-- Section Title Start -->
				<div class="section-title section-title-center">
					<span class="section-sub-title wow fadeInUp">{subtitle}</span>
					<h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
				</div>
				<!-- Section Title End -->
			</div>
		</div>

		<div class="row">
			{
				services.map((service, i) => (
					<ServiceCard
						title={service.title}
						description={service.description}
						icon={service.icon}
						url={service.url}
						delay={i % 3 === 0 ? undefined : `${(i % 3) * 0.2}s`}
					/>
				))
			}

			{
				footerText && (
					<div class="col-lg-12">
						<div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.4s">
							<div class="satisfy-client-images">
								<div class="satisfy-client-image">
									<figure class="image-anime">
										<img src="/images/author-1.jpg" alt="Мастер техпомощи" />
									</figure>
								</div>
								<div class="satisfy-client-image add-more">
									<img src="/images/icon-phone-primary.svg" alt="Телефон" />
								</div>
							</div>
							<p set:html={footerText} />
						</div>
					</div>
				)
			}
		</div>
	</div>
</div>
<!-- Our Service Section End -->
