---
// Блок вопросов-ответов хаба. Список берётся из frontmatter услуги (faqs).
// Разметка перенесена из шаблона (our-faqs bg-section), как на странице «О сервисе».
const {
	subtitle = 'Частые вопросы',
	title = 'Отвечаю на частые вопросы о техпомощи',
	description = 'Я собрал понятные ответы о выезде, услугах и порядке работы, чтобы вы заранее знали, чего ждать от моей помощи на дороге.',
	faqs = [],
} = Astro.props;
---

{
	faqs.length > 0 && (
		<div class="our-faqs bg-section">
			<div class="container">
				<div class="row">
					<div class="col-xl-5">
						<div class="faqs-content">
							<div class="section-title">
								<span class="section-sub-title wow fadeInUp">{subtitle}</span>
								<h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
								<p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
							</div>

							<div class="faqs-content-list wow fadeInUp" data-wow-delay="0.4s">
								<ul>
									<li>Круглосуточная помощь на дороге, 24/7</li>
									<li>Понятные условия и работа без навязанных услуг</li>
								</ul>
							</div>

							<div class="faqs-btn wow fadeInUp" data-wow-delay="0.6s">
								<a href="/contacts" class="btn-default">Задать вопрос</a>
							</div>
						</div>
					</div>

					<div class="col-xl-7">
						<div class="faq-contant">
							<div class="faq-accordion" id="accordion">
								{faqs.map((faq, i) => (
									<div class="accordion-item wow fadeInUp" data-wow-delay={`${i * 0.2}s`}>
										<h2 class="accordion-header" id={`heading${i}`}>
											<button
												class={i === 0 ? 'accordion-button' : 'accordion-button collapsed'}
												type="button"
												data-bs-toggle="collapse"
												data-bs-target={`#collapse${i}`}
												aria-expanded={i === 0 ? 'true' : 'false'}
												aria-controls={`collapse${i}`}
											>
												{faq.question}
											</button>
										</h2>
										<div
											id={`collapse${i}`}
											class={i === 0 ? 'accordion-collapse collapse show' : 'accordion-collapse collapse'}
											role="region"
											aria-labelledby={`heading${i}`}
											data-bs-parent="#accordion"
										>
											<div class="accordion-body">
												<p>{faq.answer}</p>
											</div>
										</div>
									</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	)
}
