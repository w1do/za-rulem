---
interface BlogPost {
	image: string;
	title: string;
	href: string;
	btnText?: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	posts?: BlogPost[];
}

const {
	subtitle = 'Блог об автомобилях',
	title = 'Полезные советы для водителей',
	description = 'Чтобы вы реже вызывали помощь, делюсь практикой: как запустить двигатель, ухаживать за аккумулятором и что делать при поломке на дороге в Тюмени.',
	posts = [
		{
			image: '/images/post-1.jpg',
			title: 'Как правильно прикурить автомобиль и не повредить электронику',
			href: '/blog',
			btnText: 'Читать статью',
		},
		{
			image: '/images/post-2.jpg',
			title: 'Почему аккумулятор разряжается и когда нужна замена',
			href: '/blog',
			btnText: 'Читать статью',
		},
		{
			image: '/images/post-3.jpg',
			title: 'Что делать при поломке автомобиля на дороге в Тюмени',
			href: '/blog',
			btnText: 'Читать статью',
		},
	],
} = Astro.props;
---

<!-- Our Blog Section Start -->
<div class="our-blog">
    <div class="container">
        <div class="row section-row">
            <div class="col-lg-12">
                <!-- Section Title Start -->
                <div class="section-title section-title-center">
                    <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                    <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                    <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                </div>
                <!-- Section Title End -->
            </div>
        </div>

        <div class="row">
            {posts.map((post, index) => (
            <div class="col-xl-4 col-md-6">
                <!-- Post Item Start -->
                <div class="post-item wow fadeInUp" data-wow-delay={index === 0 ? undefined : `${index * 0.2}s`}>
                    <!-- Post Featured Image Start -->
                    <div class="post-featured-image">
                        <a href={post.href} data-cursor-text="Читать">
                            <figure>
                                <img src={post.image} alt="" />
                            </figure>
                        </a>
                    </div>
                    <!-- Post Featured Image End -->

                    <!-- Post Item Body Start -->
                    <div class="post-item-body">
                        <!-- Post Item Content Start -->
                        <div class="post-item-content">
                            <h2><a href={post.href}>{post.title}</a></h2>
                        </div>
                        <!-- Post Item Content End -->

                        <!-- Post Item Button Start-->
                        <div class="post-item-btn">
                            <a href={post.href} class="readmore-btn">{post.btnText}</a>
                        </div>
                        <!-- Post Item Button End-->
                    </div>
                    <!-- Post Item Body End -->
                </div>
                <!-- Post Item End -->
            </div>
            ))}
        </div>
    </div>
</div>
<!-- Our Blog Section End -->