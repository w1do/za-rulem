---
interface WhyChooseItem {
	icon: string;
	title: string;
	text: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	items?: WhyChooseItem[];
	ctaText?: string;
	ctaHref?: string;
	authorName?: string;
	authorText?: string;
}

const {
	subtitle = 'Почему выбирают меня',
	title = 'Почему мне доверяют помощь на дороге',
	description = 'Приезжаю быстро, с полным набором оборудования, и берусь за любую поломку — от разряженного аккумулятора до эвакуации авто. Цену называю сразу, работаю круглосуточно и без выходных.',
	items = [
		{
			icon: '/images/icon-why-choose-body-1-gold.svg',
			title: 'Решаю любую поломку',
			text: 'Прикурю авто, заменю аккумулятор, отогрею или вскрою машину, подам эвакуатор — всё в одних руках.',
		},
		{
			icon: '/images/icon-why-choose-body-2-gold.svg',
			title: 'Приеду быстро и назову цену',
			text: 'Согласую адрес и стоимость по телефону и выезжаю сразу — обычно я на месте за 20–40 минут.',
		},
	],
	ctaText = 'Связаться со мной',
	ctaHref = '/contacts',
	authorName = 'Я — «За рулём»',
	authorText = 'Я помогаю на дороге',
} = Astro.props;
---

    <!-- Why Choose Us Section Start -->
    <div class="why-choose-us-gold">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-xl-6">
                    <!-- Why Choose Content Start -->
                    <div class="why-choose-content-gold">
                        <!-- Section Title Start -->
                        <div class="section-title">
                            <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                            <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                        </div>
                        <!-- Section Title End -->

                        <!-- Why Choose Items List Start -->
                        <div class="why-choose-items-list-gold">
                            {items.map((item, index) => (
                            <div class="why-choose-item-gold wow fadeInUp" data-wow-delay={`${0.4 + index * 0.2}s`}>
                                <div class="why-choose-item-header-gold">
                                    <div class="icon-box">
                                        <img src={item.icon} alt="" />
                                    </div>
                                    <div class="why-choose-item-title-gold">
                                        <h3>{item.title}</h3>
                                    </div>
                                </div>
                                <div class="why-choose-item-content-gold">
                                    <p>{item.text}</p>
                                </div>
                            </div>
                            ))}
                        </div>
                        <!-- Why Choose Items List End -->

                        <!-- Why Choose Footer Start -->
                        <div class="why-choose-footer-gold wow fadeInUp" data-wow-delay="0.8s">
                            <!-- Why Choose Us Button Start -->
                            <div class="why-choose-btn-gold">
                                <a href={ctaHref} class="btn-default">{ctaText}</a>
                            </div>
                            <!-- Why Choose Button End -->

                            <!-- Why Choose Author Box Start -->
                            <div class="why-choose-author-box-gold">
                                <!-- Why Choose Author Image Start -->
                                <div class="why-choose-author-image-gold">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="">
                                    </figure>
                                </div>
                                <!-- Why Choose Author Image End -->

                                <!-- Why Choose Author Content Start -->
                                <div class="why-choose-author-content-gold">
                                    <h3>{authorName}</h3>
                                    <p>{authorText}</p>
                                </div>
                                <!-- Why Choose Author Content Start -->
                            </div>
                            <!-- Why Choose Author Box End-->
                        </div>
                        <!-- Why Choose Footer End -->
                    </div>
                    <!-- Why Choose Content End -->
                </div>

                <div class="col-xl-6">
                    <!-- Why Choose Image Box Start -->
                    <div class="why-choose-image-box-gold wow fadeInUp" data-wow-delay="0.2s">
                        <!-- Why Choose Image Start -->
                        <div class="why-choose-image-gold box-1">
                            <figure class="image-anime">
                                <img src="/images/why-choose-image-1-gold.jpg" alt="">
                            </figure>
                        </div>
                        <!-- Why Choose Image End -->

                        <!-- Why Choose Image Start -->
                        <div class="why-choose-image-gold box-2">
                            <figure class="image-anime">
                                <img src="/images/why-choose-image-2-gold.jpg" alt="">
                            </figure>
                        </div>
                        <!-- Why Choose Image End -->
                    </div>
                    <!-- Why Choose Image Box End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Why Choose Us Section End -->