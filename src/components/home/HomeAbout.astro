---
---

    <!-- About Us Section Start -->
    <div class="about-us-gold">
        <div class="container">
            <div class="row section-row">
                <div class="col-xl-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">О моей техпомощи на дороге</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">Я помогаю вернуть автомобиль в движение в Тюмени</h2>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- About Info List Box Start -->
                    <div class="about-us-item-list-gold">
                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-1">
                            <!-- About Us Item Start -->
                            <div class="about-us-item-gold wow fadeInUp">
                                <div class="about-us-item-header-gold">
                                    <div class="icon-box">
                                        <img src="/images/icon-about-us-1-gold.svg" alt="">
                                    </div>
                                    <div class="about-us-item-title-gold">
                                        <h3>Моя задача</h3>
                                    </div>
                                </div>
                                <div class="about-us-item-content-gold">
                                    <p>Я помогаю на дороге в Тюмени: запускаю двигатель, меняю аккумулятор, отогреваю автомобиль и возвращаю его к движению.</p>
                                </div>
                            </div>
                            <!-- About Us Item End -->

                            <!-- About Us Item Image Start -->
                            <div class="about-us-image-gold">
                                <figure class="image-anime reveal">
                                    <img src="/images/about-us-image-1-gold.jpg" alt="">
                                </figure>
                            </div>
                            <!-- About Us Item Image End -->
                        </div>
                        <!-- About Us Item Box End -->

                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-2">
                            <!-- About Us Item Image Start -->
                            <div class="about-us-image-gold">
                                <figure class="image-anime reveal">
                                    <img src="/images/about-us-image-2-gold.jpg" alt="">
                                </figure>
                            </div>
                            <!-- About Us Item Image End -->
                        </div>
                        <!-- About Us Item Box End -->

                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-3">
                            <!-- About Us Counter Box Start -->
                            <div class="about-us-counter-box-gold wow fadeInUp">
                                <div class="about-us-counter-item-gold">
                                    <h2><span class="counter">6</span>+</h2>
                                    <p>Мои услуги на дороге</p>
                                </div>
                                <div class="about-us-counter-item-gold">
                                    <h2><span class="counter">24</span>/7</h2>
                                    <p>Я на связи</p>
                                </div>
                                <div class="about-us-counter-item-gold">
                                    <h2><span class="counter">1</span></h2>
                                    <p>Мой город — Тюмень</p>
                                </div>
                                <div class="about-us-counter-item-gold">
                                    <h2><span class="counter">1</span></h2>
                                    <p>Мой номер для вызова</p>
                                </div>
                            </div>
                            <!-- About Us Counter Box End -->

                            <!-- About Us Item Start -->
                            <div class="about-us-item-gold wow fadeInUp" data-wow-delay="0.2s">
                                <div class="about-us-item-header-gold">
                                    <div class="icon-box">
                                        <img src="/images/icon-about-us-2-gold.svg" alt="">
                                    </div>
                                    <div class="about-us-item-title-gold">
                                        <h3>Мой принцип</h3>
                                    </div>
                                </div>
                                <div class="about-us-item-content-gold">
                                    <p>Я объясняю причину неисправности, называю стоимость до начала работы и оказываю помощь аккуратно.</p>
                                </div>
                            </div>
                            <!-- About Us Item End -->
                        </div>
                        <!-- About Us Item Box End -->
                    </div>
                    <!-- About Info List Box End -->
                </div>

                <div class="col-lg-12">
                    <!-- Section Footer Text Start -->
                    <div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.4s">
                        <!-- Satisfy Client Images Start -->
                        <div class="satisfy-client-images">
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-1.jpg" alt="">
                                </figure>
                            </div>
                            <div class="satisfy-client-image add-more">
                                <img src="/images/icon-phone-primary.svg" alt="">
                            </div>
                        </div>
                        <!-- Satisfy Client Images End -->    
                        <p>Я подберу решение для поломки на дороге в Тюмени — <a href="/#contact">Позвонить мне</a></p>
                    </div>
                    <!-- Section Footer Text End -->
                </div>
            </div>
        </div>
    </div>
    <!-- About Us Section End -->