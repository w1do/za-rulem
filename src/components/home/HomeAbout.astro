---
interface AboutCounter {
	value: string;
	suffix?: string;
	label: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	taskTitle?: string;
	taskText?: string;
	principleTitle?: string;
	principleText?: string;
	counters?: AboutCounter[];
	footerText?: string;
	footerLinkText?: string;
	footerLinkHref?: string;
}

const {
	subtitle = 'Кто приедет на помощь',
	title = 'Верну вашу машину в движение на дороге в Тюмени',
	taskTitle = 'Моя задача',
	taskText = 'Прикурю авто, заменю аккумулятор, отогрею двигатель, вскрою салон или подам эвакуатор — решаю проблему прямо на месте поломки.',
	principleTitle = 'Мой принцип',
	principleText = 'Называю точную цену до начала работ, без скрытых доплат, и работаю аккуратно, не повреждая автомобиль.',
	counters = [
		{ value: '6', suffix: '+', label: 'Мои услуги на дороге' },
		{ value: '24', suffix: '/7', label: 'Я на связи' },
		{ value: '1', label: 'Мой город — Тюмень' },
		{ value: '1', label: 'Мой номер для вызова' },
	],
	footerText = 'Подберу решение для любой поломки на дороге в Тюмени —',
	footerLinkText = 'Позвонить мне',
	footerLinkHref = '/contacts',
} = Astro.props;
---

    <!-- About Us Section Start -->
    <div class="about-us-gold">
        <div class="container">
            <div class="row section-row">
                <div class="col-xl-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- About Info List Box Start -->
                    <div class="about-us-item-list-gold">
                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-1">
                            <!-- About Us Item Start -->
                            <div class="about-us-item-gold wow fadeInUp">
                                <div class="about-us-item-header-gold">
                                    <div class="icon-box">
                                        <img src="/images/icon-about-us-1-gold.svg" alt="">
                                    </div>
                                    <div class="about-us-item-title-gold">
                                        <h3>{taskTitle}</h3>
                                    </div>
                                </div>
                                <div class="about-us-item-content-gold">
                                    <p>{taskText}</p>
                                </div>
                            </div>
                            <!-- About Us Item End -->

                            <!-- About Us Item Image Start -->
                            <div class="about-us-image-gold">
                                <figure class="image-anime reveal">
                                    <img src="/images/about-us-image-1-gold.jpg" alt="">
                                </figure>
                            </div>
                            <!-- About Us Item Image End -->
                        </div>
                        <!-- About Us Item Box End -->

                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-2">
                            <!-- About Us Item Image Start -->
                            <div class="about-us-image-gold">
                                <figure class="image-anime reveal">
                                    <img src="/images/about-us-image-2-gold.jpg" alt="">
                                </figure>
                            </div>
                            <!-- About Us Item Image End -->
                        </div>
                        <!-- About Us Item Box End -->

                        <!-- About Us Item Box Start -->
                        <div class="about-us-item-box-gold box-3">
                            <!-- About Us Counter Box Start -->
                            <div class="about-us-counter-box-gold wow fadeInUp">
                                {counters.map((counter) => (
                                <div class="about-us-counter-item-gold">
                                    <h2><span class="counter">{counter.value}</span>{counter.suffix}</h2>
                                    <p>{counter.label}</p>
                                </div>
                                ))}
                            </div>
                            <!-- About Us Counter Box End -->

                            <!-- About Us Item Start -->
                            <div class="about-us-item-gold wow fadeInUp" data-wow-delay="0.2s">
                                <div class="about-us-item-header-gold">
                                    <div class="icon-box">
                                        <img src="/images/icon-about-us-2-gold.svg" alt="">
                                    </div>
                                    <div class="about-us-item-title-gold">
                                        <h3>{principleTitle}</h3>
                                    </div>
                                </div>
                                <div class="about-us-item-content-gold">
                                    <p>{principleText}</p>
                                </div>
                            </div>
                            <!-- About Us Item End -->
                        </div>
                        <!-- About Us Item Box End -->
                    </div>
                    <!-- About Info List Box End -->
                </div>

                <div class="col-lg-12">
                    <!-- Section Footer Text Start -->
                    <div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.4s">
                        <!-- Satisfy Client Images Start -->
                        <div class="satisfy-client-images">
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-1.jpg" alt="">
                                </figure>
                            </div>
                            <div class="satisfy-client-image add-more">
                                <img src="/images/icon-phone-primary.svg" alt="">
                            </div>
                        </div>
                        <!-- Satisfy Client Images End -->    
                        <p>{footerText} <a href={footerLinkHref}>{footerLinkText}</a></p>
                    </div>
                    <!-- Section Footer Text End -->
                </div>
            </div>
        </div>
    </div>
    <!-- About Us Section End -->