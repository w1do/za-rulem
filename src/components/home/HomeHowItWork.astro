---
interface WorkStep {
	icon: string;
	number: string;
	title: string;
	text: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	steps?: WorkStep[];
	footerList?: string[];
	footerText?: string;
	footerLinkText?: string;
	footerLinkHref?: string;
}

const {
	subtitle = 'Как вызвать помощь',
	title = 'Три шага — и я уже в пути',
	steps = [
		{
			icon: '/images/icon-how-it-work-1-gold.svg',
			number: '01',
			title: 'Принимаю заявку',
			text: 'Уточняю поломку и называю цену до выезда.',
		},
		{
			icon: '/images/icon-how-it-work-2-gold.svg',
			number: '02',
			title: 'Фиксирую адрес',
			text: 'Отмечаю точку в Тюмени и строю быстрый маршрут.',
		},
		{
			icon: '/images/icon-how-it-work-3-gold.svg',
			number: '03',
			title: 'Оказываю помощь',
			text: 'Прикуриваю, ремонтирую, отогреваю или эвакуирую авто.',
		},
	],
	footerList = [
		'Прикуривание автомобиля',
		'Замена аккумулятора',
		'Эвакуация автомобиля',
		'Подвоз топлива',
	],
	footerText = 'Быстро организую помощь на дороге в любое время.',
	footerLinkText = 'Вызвать помощь',
	footerLinkHref = '/contacts',
} = Astro.props;
---

    <!-- How It Work Section Start -->
    <div class="how-it-work-gold dark-section bg-section">
        <div class="container">
            <div class="row section-row">
                <div class="col-xl-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                {steps.map((step, index) => (
                <div class="col-xl-4 col-md-6">
                    <!-- How It Work Item Start -->
                    <div class="how-it-work-item-gold wow fadeInUp" data-wow-delay={index === 0 ? undefined : `${index * 0.2}s`}>
                        <div class="how-it-work-header-gold">
                            <div class="icon-box">
                                <img src={step.icon} alt="" />
                            </div>
                            <div class="how-it-work-no-gold">
                                <h3>{step.number}</h3>
                            </div>
                        </div>
                        <div class="how-it-work-body-gold">
                            <h3>{step.title}</h3>
                            <p>{step.text}</p>
                        </div>
                    </div>
                    <!-- How It Work Item End -->
                </div>
                ))}

                <div class="col-lg-12">
                    <!-- How It Work Footer Start -->
                    <div class="how-it-work-footer-gold wow fadeInUp" data-wow-delay="0.6s">
                        <!-- How It Footer List Start -->
                        <div class="how-it-footer-list-gold">
                            <ul>
                                {footerList.map((point) => (
                                <li>{point}</li>
                                ))}
                            </ul>
                        </div>
                        <!-- How It Footer List End -->

                        <!-- Section Footer Text Start -->
                        <div class="section-footer-text section-satisfy-img">
                            <!-- Satisfy Client Images Start -->
                            <div class="satisfy-client-images">
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image add-more">
                                    <img src="/images/icon-phone-white.svg" alt="">
                                </div>
                            </div>
                            <!-- Satisfy Client Images End -->    
                            <p>{footerText} <a href={footerLinkHref}>{footerLinkText}</a></p>
                        </div>
                        <!-- Section Footer Text End -->
                    </div>
                    <!-- How It Work Footer End -->
                </div>
            </div>
        </div>
    </div>
    <!-- How It Work Section End -->