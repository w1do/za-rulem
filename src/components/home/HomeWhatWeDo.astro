---
interface WhatWeCounter {
	value: string;
	title: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	counters?: WhatWeCounter[];
	checklist?: string[];
	infoTitle?: string;
	infoText?: string;
	ctaText?: string;
	ctaHref?: string;
	authorName?: string;
	authorText?: string;
}

const {
	subtitle = 'Как я работаю',
	title = 'Решаю дорожные проблемы на месте',
	description = 'Определяю причину поломки на месте и сразу берусь за дело: завожу двигатель, меняю аккумулятор, отогреваю авто или безопасно гружу его на эвакуатор.',
	counters = [
		{ value: '0.98', title: 'Довожу помощь до результата' },
		{ value: '0.85', title: 'Выезжаю с полным оборудованием' },
	],
	checklist = [
		'Принимаю заявку и сразу выезжаю',
		'Работаю круглосуточно, без выходных',
		'Помогаю на месте или подаю эвакуатор',
	],
	infoTitle = 'Работаю по всей Тюмени',
	infoText = 'Выезжаю в любую точку города и области, оцениваю проблему на месте и выбираю безопасный способ вернуть авто в движение.',
	ctaText = 'Связаться со мной',
	ctaHref = '/contacts',
	authorName = 'Я — «За рулём»',
	authorText = 'Я помогаю на дороге',
} = Astro.props;
---

    <!-- What We Do Section Start -->
    <div class="what-we-do-gold">
        <div class="container">
            <div class="row">
                <div class="col-xl-6">
                    <!-- What We Image Box Start -->
                    <div class="what-we-image-box-gold wow fadeInUp">
                        <!-- What We Image 1 Start -->
                        <div class="what-we-image-gold box-1">
                            <figure class="image-anime">
                                <img src="/images/what-we-do-image-1-gold.jpg" alt="">
                            </figure>
                        </div>
                        <!-- What We Image 1 End -->

                        <!-- What We Image 2 Start -->
                        <div class="what-we-image-gold box-2">
                            <figure class="image-anime">
                                <img src="/images/what-we-do-image-2-gold.jpg" alt="">
                            </figure>
                        </div>
                        <!-- What We Image 2 End -->
                    </div>
                    <!-- What We Image Box End -->
                </div>

                <div class="col-xl-6">
                    <!-- What We Content Start -->
                    <div class="what-we-do-content-gold">
                        <!-- Section Title Start -->
                        <div class="section-title">
                            <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                            <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                        </div>
                        <!-- Section Title End -->

                        <!-- What We Counter List Start -->
                        <div class="what-we-counter-list-gold">
                            {counters.map((counter) => (
                            <div class="what-we-counter-item-gold">
                                <div class="circle" data-size="90" data-value={counter.value}>
                                    <div class="progress_value">
                                        <span class="pro_data"></span><span>%</span>
                                    </div>
                                </div>
                                <div class="what-we-counter-item-title-gold">
                                    <h3>{counter.title}</h3>
                                </div>
                            </div>
                            ))}
                        </div>
                        <!-- What We Counter List End -->

                        <!-- What We Content Body Start -->
                        <div class="what-we-content-body-gold wow fadeInUp" data-wow-delay="0.4s">
                            <!-- What We Body List Start -->
                            <div class="what-we-body-list-gold">
                                <ul>
                                    {checklist.map((point) => (
                                    <li>{point}</li>
                                    ))}
                                </ul>
                            </div>
                            <!-- What We Body List End -->

                            <!--What We Item Box Start -->
                            <div class="what-we-info-box-gold">
                                <div class="what-we-info-header-gold">
                                    <div class="icon-box">
                                        <img src="/images/icon-what-we-do-1-gold.svg" alt="">
                                    </div>
                                    <div class="what-we-info-header-title-gold">
                                        <h3>{infoTitle}</h3>
                                    </div>
                                </div>
                                <div class="what-we-info-content-gold">
                                    <p>{infoText}</p>
                                </div>
                            </div>
                            <!--What We Item Box End -->
                        </div>
                        <!-- What We Content Body End -->

                        <!-- Why Choose Footer Start -->
                        <div class="what-we-footer-gold wow fadeInUp" data-wow-delay="0.6s">
                            <!-- Why Choose Us Button Start -->
                            <div class="what-we-btn-gold">
                                <a href={ctaHref} class="btn-default">{ctaText}</a>
                            </div>
                            <!-- Why Choose Button End -->

                            <!-- Why Choose Author Box Start -->
                            <div class="why-choose-author-box-gold">
                                <!-- Why Choose Author Image Start -->
                                <div class="why-choose-author-image-gold">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="">
                                    </figure>
                                </div>
                                <!-- Why Choose Author Image End -->

                                <!-- Why Choose Author Content Start -->
                                <div class="why-choose-author-content-gold">
                                    <h3>{authorName}</h3>
                                    <p>{authorText}</p>
                                </div>
                                <!-- Why Choose Author Content Start -->
                            </div>
                            <!-- Why Choose Author Box End -->
                        </div>
                        <!-- Why Choose Footer End -->
                    </div>
                    <!-- What We Content End -->
                </div>
            </div>
        </div>
    </div>
    <!-- What We Do Section End -->