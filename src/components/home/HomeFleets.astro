---
interface FleetSlide {
	image: string;
	alt?: string;
	cursor?: string;
	label: string;
	price: string;
	priceUnit?: string;
	amenities: string[];
	href: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	slides?: FleetSlide[];
	footerText?: string;
	footerLinkText?: string;
	footerLinkHref?: string;
}

const amenityIcons = ['/images/icon-amenity-item-1.svg', '/images/icon-amenity-item-2.svg'];

const {
	subtitle = 'Направления выезда',
	title = 'Чем помогу на дороге в Тюмени',
	slides = [
		{
			image: '/images/fleets-image-1.jpg',
			cursor: 'Замена аккумулятора',
			label: 'Замена аккумулятора',
			price: 'от 1 500 ₽',
			priceUnit: '/выезд',
			amenities: ['Привезу батарею', 'Установлю на месте'],
			href: '/services/tehpomosch/zamena-akkumulyatora',
		},
		{
			image: '/images/fleets-image-2.jpg',
			cursor: 'Отогрев авто',
			label: 'Отогрев авто',
			price: 'от 2 000 ₽',
			priceUnit: '/выезд',
			amenities: ['Отогрею двигатель', 'Заведу на месте'],
			href: '/services/tehpomosch/otogrev-avto',
		},
		{
			image: '/images/fleets-image-3.jpg',
			cursor: 'Автоэлектрик и диагностика',
			label: 'Автоэлектрик и диагностика',
			price: 'от 1 500 ₽',
			priceUnit: '/выезд',
			amenities: ['Найду причину поломки', 'Проверю электрику авто'],
			href: '/services/tehpomosch',
		},
		{
			image: '/images/fleets-image-4.jpg',
			cursor: 'Подвоз топлива',
			label: 'Подвоз топлива',
			price: 'от 1 000 ₽',
			priceUnit: '/выезд',
			amenities: ['Привезу бензин или дизель', 'Помогу запустить авто'],
			href: '/services/tehpomosch/podvoz-topliva',
		},
		{
			image: '/images/fleets-image-5.jpg',
			cursor: 'Вызвать эвакуатор',
			label: 'Эвакуатор',
			price: 'от 2 500 ₽',
			priceUnit: '/выезд',
			amenities: ['Погружу автомобиль', 'Доставлю по адресу'],
			href: '/services/tehpomosch',
		},
		{
			image: '/images/fleets-image-1.jpg',
			cursor: 'Прикурить авто',
			label: 'Прикурить авто',
			price: 'от 800 ₽',
			priceUnit: '/выезд',
			amenities: ['Подам питание', 'Запущу двигатель'],
			href: '/services/tehpomosch/prikurit-avto',
		},
	],
	footerText = 'Собрал все услуги техпомощи на дороге —',
	footerLinkText = 'посмотреть все услуги',
	footerLinkHref = '/services',
} = Astro.props;
---

    <!-- Our Fleets Section Start -->
    <div class="our-fleets bg-section">
        <div class="container">
            <div class="row section-row">
                <div class="col-xl-12">
                    <!-- Section Title Start -->
                    <div class="section-title section-title-center">
                        <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                        <h2 class="text-anime-style-3" data-cursor="-opaque">{title}</h2>
                    </div>
                    <!-- Section Title End -->
                </div>
            </div>

            <div class="row">
                <div class="col-lg-12">
                    <!-- Fleets Slider Start -->
                    <div class="fleets-slider wow fadeInUp" data-wow-delay="0.2s">
                        <div class="swiper">
                            <div class="swiper-wrapper">
                                {slides.map((slide) => (
                                <div class="swiper-slide">
                                    <div class="fleets-item">
                                        <!-- Fleets Item Image Start -->
                                        <div class="fleets-item-image">
                                            <a href={slide.href} data-cursor-text={slide.cursor}>
                                                <figure>
                                                    <img src={slide.image} alt={slide.alt ?? slide.label} />
                                                </figure>
                                            </a>
                                        </div>
                                        <!-- Fleets Item Image End -->

                                        <!-- Fleets Item Button Start -->
                                        <div class="fleets-item-btn">
                                            <a href={slide.href}><img src="/images/arrow-primary.svg" alt="" /></a>
                                        </div>
                                        <!-- Project Item Button End -->

                                        <!-- Fleets Item Body Start -->
                                        <div class="fleets-item-body">
                                            <!-- Fleets Item Content Start -->
                                            <div class="fleets-item-content">
                                                <p>{slide.label}</p>
                                                <h2>{slide.price} <sub>{slide.priceUnit}</sub></h2>
                                            </div>
                                            <!-- Fleets Item Content End -->

                                            <!-- Fleets Amenity Item List Start -->
                                            <div class="fleets-amenity-item-list">
                                                <ul>
                                                    {slide.amenities.map((amenity, index) => (
                                                    <li><img src={amenityIcons[index] ?? amenityIcons[0]} alt="" />{amenity}</li>
                                                    ))}
                                                </ul>
                                            </div>
                                            <!-- Fleets Amenity Item List End -->
                                        </div>
                                        <!-- Fleets Item Header Box End -->
                                    </div>
                                </div>
                                ))}
                            </div>
                            <div class="fleets-pagination"></div>
                        </div>
                    </div>
                    <!-- Fleets Slider End -->
                </div>

                <div class="col-lg-12">
                    <!-- Section Footer Text Start -->
                    <div class="section-footer-text section-satisfy-img wow fadeInUp" data-wow-delay="0.2s">
                        <!-- Satisfy Client Images Start -->
                        <div class="satisfy-client-images">
                            <div class="satisfy-client-image">
                                <figure class="image-anime">
                                    <img src="/images/author-1.jpg" alt="">
                                </figure>
                            </div>
                            <div class="satisfy-client-image add-more">
                                <img src="/images/icon-phone-primary.svg" alt="">
                            </div>
                        </div>
                        <!-- Satisfy Client Images End -->    
                        <p>{footerText} <a href={footerLinkHref}>{footerLinkText}</a></p>
                    </div>
                    <!-- Section Footer Text End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Our Fleets Section End -->
