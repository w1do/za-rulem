---
interface HeroBenefit {
	icon: string;
	title: string;
	text: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	ctaText?: string;
	ctaHref?: string;
	reviewText?: string;
	counterValue?: string;
	counterText?: string;
	benefits?: HeroBenefit[];
}

const {
	subtitle = 'Техпомощь на дороге в Тюмени 24/7',
	title = 'Срочная автопомощь на дороге в Тюмени с выездом',
	description = 'Приеду за 20–40 минут и заведу вашу машину: прикурю авто, заменю аккумулятор с выездом, отогрею двигатель, вскрою салон, привезу топливо или подам эвакуатор. Работаю круглосуточно по Тюмени. Звоните: +7 908 871-20-26.',
	ctaText = 'Вызвать помощь',
	ctaHref = '/contacts',
	reviewText = 'Круглосуточно на связи с водителями Тюмени',
	counterValue = '6',
	counterText = 'Шесть видов техпомощи на дороге — приеду с готовым оборудованием и решу проблему на месте.',
	benefits = [
		{
			icon: '/images/icon-hero-info-list-1-gold.svg',
			title: '01. Позвоните мне',
			text: 'Опишите поломку по телефону — подскажу решение и назову цену до выезда.',
		},
		{
			icon: '/images/icon-hero-info-list-2-gold.svg',
			title: '02. Я выезжаю',
			text: 'Уточню адрес в Тюмени и сразу выезжаю к вам с нужным оборудованием.',
		},
		{
			icon: '/images/icon-hero-info-list-3-gold.svg',
			title: '03. Завожу на месте',
			text: 'Прикурю авто, заменю аккумулятор или подам эвакуатор, если ремонт на месте невозможен.',
		},
	],
} = Astro.props;
---

    <!-- Hero Section Start -->
    <div class="hero-gold dark-section parallaxie">
        <div class="container">
            <div class="row">
                <div class="col-xl-8">
                    <!-- Hero Content Start -->
                    <div class="hero-content-gold">
                        <!-- Section Title Start -->
                        <div class="section-title">
                            <span class="section-sub-title wow fadeInUp">{subtitle}</span>
                            <h1 class="text-anime-style-3" data-cursor="-opaque">{title}</h1>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">{description}</p>
                        </div>
                        <!-- Section Title End -->
                        
                        <!-- Hero Content Button Start -->
                        <div class="hero-content-btn-gold wow fadeInUp" data-wow-delay="0.4s">
                            <a href={ctaHref} class="btn-default btn-highlighted">{ctaText}</a>
                        </div>
                        <!-- Hero Content Button End -->
                    </div>
                    <!-- Hero Content End -->
                </div>

                <div class="col-xl-4">
                    <!-- Hero Info Client Box Start -->
                    <div class="hero-info-client-box-gold wow fadeInUp">
                        <!-- Hero Client Review Box Start -->
                        <div class="hero-client-review-box-gold">
                            <!-- Hero Client Review Counter Start -->
                            <div class="hero-client-review-counter-gold">
                                <p>{reviewText}</p>
                            </div>
                            <!-- Hero Client Review Counter End -->

                            <!-- Satisfy Client Images Start -->
                            <div class="satisfy-client-images">
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-2.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-3.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-4.jpg" alt="">
                                    </figure>
                                </div>
                            </div>
                            <!-- Satisfy Client Images End -->
                        </div>
                        <!-- Hero Client Review Box End -->

                        <!-- Hero Client Counter Box Start -->
                        <div class="hero-client-counter-box-gold">
                            <h2><span class="counter">{counterValue}</span>+</h2>
                            <p>{counterText}</p>
                        </div>
                        <!-- Hero Client Counter Box End -->
                    </div>
                    <!-- Hero Info Client Box End -->
                </div>

                <div class="col-lg-12">
                    <!-- Hero Benefit Item List Start -->
                    <div class="hero-benefit-item-list-gold">
                        {benefits.map((item, index) => (
                        <div class="hero-benefit-item-gold wow fadeInUp" data-wow-delay={index === 0 ? undefined : `${index * 0.2}s`}>
                            <div class="icon-box">
                                <img src={item.icon} alt="" />
                            </div>
                            <div class="hero-benefit-item-content-gold">
                                <h3>{item.title}</h3>
                                <p>{item.text}</p>
                            </div>
                        </div>
                        ))}
                    </div>
                    <!-- Hero Benefit Item List End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Hero Section End -->