---
---

    <!-- Hero Section Start -->
    <div class="hero-gold dark-section parallaxie">
        <div class="container">
            <div class="row">
                <div class="col-xl-8">
                    <!-- Hero Content Start -->
                    <div class="hero-content-gold">
                        <!-- Section Title Start -->
                        <div class="section-title">
                            <span class="section-sub-title wow fadeInUp">Техпомощь на дороге в Тюмени</span>
                            <h1 class="text-anime-style-3" data-cursor="-opaque">Я быстро помогу вернуть автомобиль в движение</h1>
                            <p class="wow fadeInUp" data-wow-delay="0.2s">Я приеду по Тюмени и помогу на дороге: прикурю автомобиль, заменю аккумулятор, выполню отогрев, вскрытие, подвоз топлива или эвакуацию. Я принимаю вызовы по телефону +7 908 871-20-26.</p>
                        </div>
                        <!-- Section Title End -->
                        
                        <!-- Hero Content Button Start -->
                        <div class="hero-content-btn-gold wow fadeInUp" data-wow-delay="0.4s">
                            <a href="/#contact" class="btn-default btn-highlighted">Вызвать помощь</a>
                        </div>
                        <!-- Hero Content Button End -->
                    </div>
                    <!-- Hero Content End -->
                </div>

                <div class="col-xl-4">
                    <!-- Hero Info Client Box Start -->
                    <div class="hero-info-client-box-gold wow fadeInUp">
                        <!-- Hero Client Review Box Start -->
                        <div class="hero-client-review-box-gold">
                            <!-- Hero Client Review Counter Start -->
                            <div class="hero-client-review-counter-gold">
                                <p>Я на связи с водителями в Тюмени</p>
                            </div>
                            <!-- Hero Client Review Counter End -->

                            <!-- Satisfy Client Images Start -->
                            <div class="satisfy-client-images">
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-1.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-2.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-3.jpg" alt="">
                                    </figure>
                                </div>
                                <div class="satisfy-client-image">
                                    <figure class="image-anime">
                                        <img src="/images/author-4.jpg" alt="">
                                    </figure>
                                </div>
                            </div>
                            <!-- Satisfy Client Images End -->
                        </div>
                        <!-- Hero Client Review Box End -->

                        <!-- Hero Client Counter Box Start -->
                        <div class="hero-client-counter-box-gold">
                            <h2><span class="counter">6</span>+</h2>
                            <p>Я оказываю шесть видов техпомощи на дороге в Тюмени и приеду с нужным оборудованием.</p>
                        </div>
                        <!-- Hero Client Counter Box End -->
                    </div>
                    <!-- Hero Info Client Box End -->
                </div>

                <div class="col-lg-12">
                    <!-- Hero Benefit Item List Start -->
                    <div class="hero-benefit-item-list-gold">
                        <!-- Hero Benefit Item Start -->
                        <div class="hero-benefit-item-gold wow fadeInUp">
                            <div class="icon-box">
                                <img src="/images/icon-hero-info-list-1-gold.svg" alt="">
                            </div>
                            <div class="hero-benefit-item-content-gold">
                                <h3>01. Я приеду к автомобилю</h3>
                                <p>Я уточню адрес в Тюмени и направлюсь к автомобилю с необходимыми инструментами.</p>
                            </div>
                        </div>
                        <!-- Hero Benefit Item End -->

                        <!-- Hero Benefit Item Start -->
                        <div class="hero-benefit-item-gold wow fadeInUp" data-wow-delay="0.2s">
                            <div class="icon-box">
                                <img src="/images/icon-hero-info-list-2-gold.svg" alt="">
                            </div>
                            <div class="hero-benefit-item-content-gold">
                                <h3>02. Я отвечу на звонок</h3>
                                <p>Я выслушаю описание неисправности, подскажу решение и согласую порядок помощи.</p>
                            </div>
                        </div>
                        <!-- Hero Benefit Item End -->

                        <!-- Hero Benefit Item Start -->
                        <div class="hero-benefit-item-gold wow fadeInUp" data-wow-delay="0.4s">
                            <div class="icon-box">
                                <img src="/images/icon-hero-info-list-3-gold.svg" alt="">
                            </div>
                            <div class="hero-benefit-item-content-gold">
                                <h3>03. Я помогу на месте</h3>
                                <p>Я запущу двигатель, отогрею автомобиль или организую эвакуацию, если ремонт на месте невозможен.</p>
                            </div>
                        </div>
                        <!-- Hero Benefit Item End -->
                    </div>
                    <!-- Hero Benefit Item List End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Hero Section End -->